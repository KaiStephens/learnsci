# Use one OpenRouter key for the full pipeline.
# OPENAI_API_KEY is accepted by the app as a local alias, but these Microsoft
# MAI models are routed through OpenRouter, so an OpenRouter key is the right key.
OPENROUTER_API_KEY=sk-or-v1-replace-me

LEARNSCI_TRANSCRIBE_MODEL=microsoft/mai-transcribe-1.5
LEARNSCI_LLM_MODEL=openai/gpt-5.4-mini
LEARNSCI_SPEECH_MODEL=microsoft/mai-voice-2
LEARNSCI_SPEECH_VOICE=en-US-Harper:MAI-Voice-2
